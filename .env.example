DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
XTREAM_USER=admin
XTREAM_PASS=admin
ENABLE_TV_SERVER=1
ENABLE_YOUTUBE_PROXY=1
YOUTUBE_PROXY_HOST=0.0.0.0
YOUTUBE_PROXY_PORT=5000
PORT=3000
XTREAM_PORT=8080
DATA_DIR=./data
# HLS streaming server public base URL (panel uses this to generate /hls links)
# Local dev: http://localhost:3000
# Production: https://stream.example.com
STREAM_BASE_URL=
# YouTube stream URL cache duration (milliseconds, default: 600000 = 10 minutes)
STREAM_CACHE_MS=600000
